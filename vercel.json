{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "pip3 install --quiet pillow && python3 build_static.py",
  "outputDirectory": "dist",
  "functions": {
    "api/*.js": { "maxDuration": 30 }
  },
  "cleanUrls": true,
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
